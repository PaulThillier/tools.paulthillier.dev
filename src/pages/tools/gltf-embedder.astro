---
// src/pages/tools/gltf-embedder.astro
import ToolLayout from '../../layouts/ToolLayout.astro';
---


<ToolLayout
  title="GLTF Embedder"
  description="Upload a .gltf with its companion .bin buffers and textures. All external references are base64-embedded into a single self-contained .gltf."
  icon="3D"
  category="3D / Models"
>

<style>
  /* Size limit notice */
  .size-limit {
    margin-bottom: 20px;
    padding: 10px 14px;
    background: rgba(255,200,100,0.05);
    border: 1px solid rgba(255,200,100,0.2);
    border-radius: 8px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--warn);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  /* Drop zone */
  .drop-zone {
    border: 1.5px dashed var(--border);
    border-radius: 12px;
    padding: 44px 32px;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
    position: relative;
    background: var(--surface);
  }
  .drop-zone:hover, .drop-zone.dragover {
    border-color: var(--accent);
    background: rgba(127,255,110,0.04);
  }
  .drop-zone input[type="file"] {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
    width: 100%;
    height: 100%;
  }
  .drop-icon { font-size: 36px; margin-bottom: 16px; display: block; }
  .drop-title {
    font-family: var(--mono);
    font-size: 15px;
    color: var(--text);
    margin-bottom: 6px;
  }
  .drop-hint { font-size: 13px; color: var(--muted); line-height: 1.7; }
  .drop-hint code { font-family: var(--mono); font-size: 12px; padding: 1px 5px; border-radius: 3px; }
  .drop-hint code.gltf { background: rgba(127,255,110,0.08); color: var(--accent); }
  .drop-hint code.bin  { background: rgba(79,195,247,0.08);  color: var(--accent2); }
  .drop-hint code.tex  { background: rgba(255,200,100,0.08); color: var(--warn); }

  /* File list */
  .file-list { margin-top: 20px; display: flex; flex-direction: column; gap: 8px; }
  .file-item {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 14px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    font-family: var(--mono);
    font-size: 12px;
  }
  .file-item.rejected { border-color: rgba(255,107,107,0.3); background: rgba(255,107,107,0.04); }
  .fname { flex: 1; color: var(--text); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .fsize { color: var(--muted); font-size: 11px; flex-shrink: 0; }
  .file-tag { font-size: 10px; padding: 2px 7px; border-radius: 3px; font-weight: 700; letter-spacing: 0.5px; flex-shrink: 0; }
  .tag-gltf { background: rgba(127,255,110,0.15); color: var(--accent); }
  .tag-bin  { background: rgba(79,195,247,0.15);  color: var(--accent2); }
  .tag-tex  { background: rgba(255,200,100,0.15); color: var(--warn); }
  .tag-rej  { background: rgba(255,107,107,0.15); color: var(--danger); }
  .reject-msg { font-size: 10px; color: var(--danger); flex-shrink: 0; }

  /* Buttons */
  .btn-row { margin-top: 28px; display: flex; justify-content: flex-end; gap: 12px; }
  button {
    font-family: var(--mono); font-size: 13px; font-weight: 700;
    border: none; border-radius: 8px; cursor: pointer;
    padding: 11px 24px; transition: all 0.15s;
  }
  .btn-clear { background: transparent; border: 1px solid var(--border); color: var(--muted); }
  .btn-clear:hover { border-color: var(--danger); color: var(--danger); }
  .btn-convert { background: var(--accent); color: #0c0c0f; }
  .btn-convert:hover:not(:disabled) { filter: brightness(1.1); transform: translateY(-1px); }
  .btn-convert:disabled { opacity: 0.35; cursor: not-allowed; transform: none; }

  /* Progress */
  .progress-wrap { margin-top: 16px; height: 3px; background: var(--border); border-radius: 2px; overflow: hidden; display: none; }
  .progress-wrap.visible { display: block; }
  .progress-bar { height: 100%; background: var(--accent); width: 0%; transition: width 0.2s; border-radius: 2px; }

  /* Log */
  .log-box {
    margin-top: 28px; background: var(--surface); border: 1px solid var(--border);
    border-radius: 10px; padding: 16px 18px; font-family: var(--mono);
    font-size: 12px; line-height: 1.8; max-height: 240px; overflow-y: auto; display: none;
  }
  .log-box.visible { display: block; }
  .log-line       { color: var(--muted); }
  .log-line.info  { color: var(--text); }
  .log-line.ok    { color: var(--accent); }
  .log-line.warn  { color: var(--warn); }
  .log-line.error { color: var(--danger); }

  /* Download */
  .download-area {
    margin-top: 28px; padding: 22px 24px;
    background: rgba(127,255,110,0.06);
    border: 1px solid rgba(127,255,110,0.25);
    border-radius: 12px; display: none; align-items: center; gap: 16px;
  }
  .download-area.visible { display: flex; }
  .dl-info { flex: 1; }
  .dl-name { font-family: var(--mono); font-size: 14px; color: var(--accent); margin-bottom: 3px; word-break: break-all; }
  .dl-meta { font-size: 12px; color: var(--muted); }
  .btn-dl { background: var(--accent); color: #0c0c0f; padding: 10px 20px; flex-shrink: 0; }
  .btn-dl:hover { filter: brightness(1.1); }
</style>

<!-- Size cap notice -->
<div class="size-limit">⚠ Max 200 MB per file · very large textures may slow your browser</div>

<!-- Drop zone -->
<div class="drop-zone" id="dropZone">
  <input type="file" id="fileInput" multiple
    accept=".gltf,.bin,.png,.jpg,.jpeg,.webp,.ktx,.ktx2,.basis,.dds" />
  <span class="drop-icon">📦</span>
  <div class="drop-title">Drop files here or click to browse</div>
  <div class="drop-hint">
    Select <code class="gltf">.gltf</code> + any <code class="bin">.bin</code> buffers + <code class="tex">textures</code>.<br />
    All files must be uploaded together. Only whitelisted file types accepted.
  </div>
</div>

<div class="file-list" id="fileList"></div>

<div class="btn-row">
  <button class="btn-clear" id="btnClear" style="display:none">Clear</button>
  <button class="btn-convert" id="btnConvert" disabled>Embed &amp; Convert →</button>
</div>

<div class="progress-wrap" id="progressWrap">
  <div class="progress-bar" id="progressBar"></div>
</div>

<div class="log-box" id="logBox"></div>

<div class="download-area" id="downloadArea">
  <div class="dl-info">
    <div class="dl-name" id="dlName"></div>
    <div class="dl-meta" id="dlMeta"></div>
  </div>
  <button class="btn-dl" id="btnDl">Download ↓</button>
</div>

<script>
(function () {
  'use strict';

  // ── Security constants ────────────────────────────────────────────────────
  const MAX_FILE_SIZE   = 200 * 1024 * 1024; // 200 MB hard cap per file
  const MAX_TOTAL_FILES = 64;
  const ALLOWED_EXTS    = new Set(['gltf','bin','png','jpg','jpeg','webp','ktx','ktx2','basis','dds']);
  const MIME_MAP        = Object.freeze({
    png:   'image/png',
    jpg:   'image/jpeg',
    jpeg:  'image/jpeg',
    webp:  'image/webp',
    ktx:   'image/ktx',
    ktx2:  'image/ktx2',
    basis: 'image/basis',
    dds:   'image/vnd-ms.dds',
  });

  // ── State ─────────────────────────────────────────────────────────────────
  const fileMap  = new Map(); // filename → File
  let outputBlob = null;
  let outputName = '';

  // ── DOM refs ──────────────────────────────────────────────────────────────
  const dropZone     = document.getElementById('dropZone');
  const fileInput    = document.getElementById('fileInput');
  const fileListEl   = document.getElementById('fileList');
  const btnConvert   = document.getElementById('btnConvert');
  const btnClear     = document.getElementById('btnClear');
  const logBox       = document.getElementById('logBox');
  const progressWrap = document.getElementById('progressWrap');
  const progressBar  = document.getElementById('progressBar');
  const downloadArea = document.getElementById('downloadArea');
  const dlName       = document.getElementById('dlName');
  const dlMeta       = document.getElementById('dlMeta');
  const btnDl        = document.getElementById('btnDl');

  // ── Drag & drop ───────────────────────────────────────────────────────────
  dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('dragover'); });
  dropZone.addEventListener('dragleave', () => dropZone.classList.remove('dragover'));
  dropZone.addEventListener('drop', e => {
    e.preventDefault();
    dropZone.classList.remove('dragover');
    addFiles([...e.dataTransfer.files]);
  });
  fileInput.addEventListener('change', () => { addFiles([...fileInput.files]); fileInput.value = ''; });

  // ── File ingestion + validation ───────────────────────────────────────────
  function getExt(name) {
    return name.split('.').pop().toLowerCase().trim();
  }

  function addFiles(files) {
    if (fileMap.size + files.length > MAX_TOTAL_FILES) {
      alert('Too many files. Max ' + MAX_TOTAL_FILES + ' at once.');
      return;
    }
    files.forEach(f => { if (!fileMap.has(f.name)) fileMap.set(f.name, f); });
    renderFileList();
  }

  function renderFileList() {
    const files = [...fileMap.values()];
    fileListEl.innerHTML = '';

    if (!files.length) {
      btnConvert.disabled = true;
      btnClear.style.display = 'none';
      return;
    }

    let hasGltf = false, hasErrors = false;

    files.forEach(f => {
      const ext      = getExt(f.name);
      const allowed  = ALLOWED_EXTS.has(ext);
      const tooBig   = f.size > MAX_FILE_SIZE;
      const rejected = !allowed || tooBig;
      if (rejected) hasErrors = true;

      let tag = 'unk', label = ext.toUpperCase();
      if (ext === 'gltf')                                                      { tag = 'gltf'; label = 'GLTF'; if (!rejected) hasGltf = true; }
      else if (ext === 'bin')                                                   { tag = 'bin';  label = 'BIN'; }
      else if (['png','jpg','jpeg','webp','ktx','ktx2','basis','dds'].includes(ext)) { tag = 'tex';  label = 'TEX'; }
      if (rejected) tag = 'rej';

      const item = document.createElement('div');
      item.className = 'file-item' + (rejected ? ' rejected' : '');
      item.innerHTML =
        '<span class="file-tag tag-' + sanitizeAttr(tag) + '">' + sanitizeText(label) + '</span>' +
        '<span class="fname">'  + sanitizeText(f.name)           + '</span>' +
        '<span class="fsize">'  + sanitizeText(fmtSize(f.size))  + '</span>' +
        (tooBig         ? '<span class="reject-msg">TOO LARGE</span>'    : '') +
        (!allowed && !tooBig ? '<span class="reject-msg">BLOCKED TYPE</span>' : '');
      fileListEl.appendChild(item);
    });

    btnConvert.disabled = !hasGltf || hasErrors;
    btnClear.style.display = 'inline-block';
  }

  // ── Clear ─────────────────────────────────────────────────────────────────
  btnClear.addEventListener('click', () => {
    fileMap.clear(); outputBlob = null; outputName = '';
    renderFileList();
    logBox.classList.remove('visible');
    progressWrap.classList.remove('visible');
    downloadArea.classList.remove('visible');
    logBox.innerHTML = '';
    progressBar.style.width = '0%';
  });

  // ── Logging ───────────────────────────────────────────────────────────────
  function log(msg, type = 'log') {
    logBox.classList.add('visible');
    const line = document.createElement('div');
    line.className = 'log-line ' + type;
    line.textContent = timestamp() + ' ' + msg;
    logBox.appendChild(line);
    logBox.scrollTop = logBox.scrollHeight;
  }
  function timestamp() {
    const d = new Date();
    return '[' + pad(d.getHours()) + ':' + pad(d.getMinutes()) + ':' + pad(d.getSeconds()) + ']';
  }
  function pad(n) { return String(n).padStart(2, '0'); }
  function setProgress(pct) {
    progressWrap.classList.add('visible');
    progressBar.style.width = Math.min(100, Math.max(0, pct)) + '%';
  }

  // ── Conversion ────────────────────────────────────────────────────────────
  btnConvert.addEventListener('click', async () => {
    btnConvert.disabled = true;
    btnClear.disabled   = true;
    downloadArea.classList.remove('visible');
    logBox.innerHTML    = '';
    setProgress(0);
    try { await embedGltf(); }
    catch (err) { log('❌ ' + String(err.message || err), 'error'); console.error(err); }
    finally { btnConvert.disabled = false; btnClear.disabled = false; }
  });

  async function embedGltf() {
    const gltfFile = [...fileMap.values()].find(f => getExt(f.name) === 'gltf');
    if (!gltfFile) throw new Error('No .gltf file found.');
    if (gltfFile.size > 50 * 1024 * 1024) throw new Error('.gltf JSON is unexpectedly large (>50 MB).');

    log('Parsing ' + gltfFile.name + '…', 'info');
    const gltfText = await readText(gltfFile);
    let gltf;
    try { gltf = JSON.parse(gltfText); } catch (e) { throw new Error('Invalid GLTF JSON: ' + e.message); }
    if (typeof gltf !== 'object' || !gltf.asset) throw new Error('Missing GLTF asset object.');
    if (gltf.asset.version && !gltf.asset.version.startsWith('2'))
      log('⚠ GLTF version ' + gltf.asset.version + ' — only 2.x is tested.', 'warn');

    log('GLTF version: ' + (gltf.asset?.version ?? 'unknown'), 'info');
    setProgress(10);

    const totalSteps = (gltf.buffers?.length || 0) + (gltf.images?.length || 0) || 1;
    let done = 0;

    // Embed buffers
    if (Array.isArray(gltf.buffers) && gltf.buffers.length) {
      log('Embedding ' + gltf.buffers.length + ' buffer(s)…', 'info');
      for (let i = 0; i < gltf.buffers.length; i++) {
        const buf = gltf.buffers[i];
        if (buf.uri && !buf.uri.startsWith('data:')) {
          const name = sanitizeFilename(decodeURIComponent(buf.uri.split('/').pop()));
          const file = findFile(name);
          if (!file) throw new Error('Buffer not found: "' + name + '". Upload it with the .gltf.');
          log('  buffer[' + i + ']: ' + name + ' (' + fmtSize(file.size) + ')', 'log');
          buf.uri = 'data:application/octet-stream;base64,' + await readBase64(file);
        } else if (!buf.uri) {
          log('  buffer[' + i + ']: already embedded', 'log');
        }
        done++; setProgress(10 + Math.round((done / totalSteps) * 70));
      }
      log('✔ Buffers embedded', 'ok');
    } else { log('No external buffers.', 'log'); }

    // Embed images
    if (Array.isArray(gltf.images) && gltf.images.length) {
      log('Embedding ' + gltf.images.length + ' image(s)…', 'info');
      for (let i = 0; i < gltf.images.length; i++) {
        const img = gltf.images[i];
        if (img.uri && !img.uri.startsWith('data:')) {
          const name = sanitizeFilename(decodeURIComponent(img.uri.split('/').pop()));
          const file = findFile(name);
          if (!file) throw new Error('Texture not found: "' + name + '". Upload it with the .gltf.');
          const mime = mimeForFile(file.name);
          log('  image[' + i + ']: ' + name + ' → ' + mime + ' (' + fmtSize(file.size) + ')', 'log');
          img.uri = 'data:' + mime + ';base64,' + await readBase64(file);
          if (!img.mimeType) img.mimeType = mime;
        } else if (img.bufferView !== undefined) {
          log('  image[' + i + ']: already in bufferView', 'log');
        }
        done++; setProgress(10 + Math.round((done / totalSteps) * 70));
      }
      log('✔ Images embedded', 'ok');
    } else { log('No external images.', 'log'); }

    setProgress(90);
    log('Serializing…', 'info');
    const outJson = JSON.stringify(gltf, null, 2);
    outputBlob    = new Blob([outJson], { type: 'model/gltf+json' });
    outputName    = gltfFile.name.replace(/\.gltf$/i, '') + '.embedded.gltf';
    setProgress(100);
    log('✔ Done — ' + outputName + ' (' + fmtSize(outputBlob.size) + ')', 'ok');

    dlName.textContent = outputName;
    dlMeta.textContent = fmtSize(outputBlob.size) + ' · self-contained GLTF, all assets embedded';
    downloadArea.classList.add('visible');

    btnDl.onclick = () => {
      const url = URL.createObjectURL(outputBlob);
      const a   = document.createElement('a');
      a.href = url; a.download = outputName;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      setTimeout(() => URL.revokeObjectURL(url), 5000);
    };
  }

  // ── Helpers ───────────────────────────────────────────────────────────────
  function findFile(name) {
    if (fileMap.has(name)) return fileMap.get(name);
    const lower = name.toLowerCase();
    for (const [, f] of fileMap) if (f.name.toLowerCase() === lower) return f;
    return null;
  }
  function sanitizeFilename(name) {
    return String(name).replace(/\0/g, '').replace(/^.*[/\\]/, '').trim();
  }
  function sanitizeText(str) {
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }
  function sanitizeAttr(str) { return String(str).replace(/[^a-z0-9-]/gi, ''); }
  function readText(file) {
    return new Promise((res, rej) => { const r = new FileReader(); r.onload = () => res(r.result); r.onerror = () => rej(new Error('Failed to read ' + file.name)); r.readAsText(file); });
  }
  function readBase64(file) {
    return new Promise((res, rej) => { const r = new FileReader(); r.onload = () => { const i = r.result.indexOf(','); i === -1 ? rej(new Error('Bad data URL')) : res(r.result.slice(i + 1)); }; r.onerror = () => rej(new Error('Failed to read ' + file.name)); r.readAsDataURL(file); });
  }
  function mimeForFile(name) { return MIME_MAP[getExt(name)] || 'application/octet-stream'; }
  function fmtSize(bytes) {
    if (bytes < 1024)    return bytes + ' B';
    if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
    return (bytes / 1048576).toFixed(2) + ' MB';
  }
})();
</script>

</ToolLayout>
